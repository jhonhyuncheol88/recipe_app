# Define a global iOS platform for the project
platform :ios, '16.0'
$iOSVersion = '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

def remove_stale_pods_runner_frameworks
  project_path = File.join(__dir__, 'Runner.xcodeproj')
  project = Xcodeproj::Project.open(project_path)
  stale_frameworks = ['Pods_Runner.framework', 'Pods_RunnerTests.framework']
  changed = false

  project.targets.each do |target|
    target.frameworks_build_phase.files.dup.each do |build_file|
      next unless stale_frameworks.include?(build_file.display_name)

      build_file.remove_from_project
      changed = true
    end
  end

  project.files.each do |file|
    next unless stale_frameworks.include?(file.display_name) || stale_frameworks.include?(file.path)

    file.remove_from_project
    changed = true
  end

  project.targets.each do |target|
    next unless ['Runner', 'RunnerTests'].include?(target.name)

    target.build_configurations.each do |config|
      next if config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] == 'arm64'

      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
      changed = true
    end
  end

  project.save if changed
end

post_install do |installer|
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['EXCLUDED_ARCHS[sdk=iphoneos*]'] = 'armv7'
    config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = $iOSVersion
  end

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['EXCLUDED_ARCHS[sdk=iphoneos*]'] = 'armv7'

      deployment_target = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] || '0'
      if Gem::Version.new($iOSVersion) > Gem::Version.new(deployment_target)
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = $iOSVersion
      end
    end
  end
end

post_integrate do |_installer|
  remove_stale_pods_runner_frameworks
end